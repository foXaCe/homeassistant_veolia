{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "forkProcessing": "enabled",
  "extends": [
    "config:recommended",
    ":semanticCommits",
    ":semanticCommitTypeAll(deps)",
    "group:allNonMajor",
    ":dependencyDashboard",
    ":enableVulnerabilityAlertsWithLabel(security)",
    ":timezone(Europe/Paris)",
    ":separatePatchReleases",
    "schedule:nonOfficeHours"
  ],
  "labels": ["dependencies"],
  "assignees": ["foXaCe"],
  "prCreation": "immediate",
  "prHourlyLimit": 4,
  "prConcurrentLimit": 10,
  "rangeStrategy": "auto",
  "rebaseWhen": "auto",
  "minimumReleaseAge": "3 days",
  "internalChecksFilter": "strict",
  "dependencyDashboard": true,
  "dependencyDashboardTitle": "📦 Renovate Dependency Dashboard",
  "dependencyDashboardLabels": ["dependencies"],
  "configMigration": true,
  "vulnerabilityAlerts": {
    "labels": ["security", "dependencies"],
    "minimumReleaseAge": null,
    "schedule": ["at any time"],
    "prCreation": "immediate"
  },
  "packageRules": [
    {
      "matchUpdateTypes": ["patch", "pin", "digest"],
      "automerge": true,
      "platformAutomerge": true,
      "labels": ["dependencies", "auto-merge"]
    },
    {
      "matchUpdateTypes": ["minor"],
      "automerge": false,
      "labels": ["dependencies"]
    },
    {
      "matchUpdateTypes": ["major"],
      "automerge": false,
      "labels": ["dependencies", "breaking change"],
      "minimumReleaseAge": "7 days"
    },
    {
      "matchManagers": ["pip_requirements", "pep621"],
      "labels": ["dependencies", "python"]
    },
    {
      "matchManagers": ["github-actions"],
      "labels": ["dependencies", "github-actions"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchManagers": ["pre-commit"],
      "labels": ["dependencies"],
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchDepNames": ["homeassistant"],
      "labels": ["dependencies", "homeassistant"],
      "automerge": false,
      "minimumReleaseAge": "14 days",
      "schedule": ["before 6am on the first day of the month"]
    },
    {
      "matchPackageNames": ["/^ruff/", "/^mypy/"],
      "groupName": "lint & format tools",
      "automerge": true,
      "platformAutomerge": true
    },
    {
      "matchPackageNames": ["/^pytest/"],
      "groupName": "pytest stack"
    }
  ],
  "customManagers": [
    {
      "customType": "regex",
      "description": "Update PyPI requirements pinned in the Home Assistant manifest.json",
      "managerFilePatterns": ["/custom_components/veolia/manifest\\.json$/"],
      "matchStrings": ["\"(?<depName>[a-zA-Z0-9._-]+)==(?<currentValue>[0-9][0-9a-zA-Z.]*)\""],
      "datasourceTemplate": "pypi"
    },
    {
      "customType": "regex",
      "description": "Update the veolia_api git fork tag in manifest.json and requirements.txt",
      "managerFilePatterns": [
        "/custom_components/veolia/manifest\\.json$/",
        "/requirements\\.txt$/"
      ],
      "matchStrings": [
        "git\\+https://github\\.com/(?<depName>[^@\\s\"]+)@(?<currentValue>v[0-9][^\\s\"]*)"
      ],
      "datasourceTemplate": "github-tags"
    }
  ],
  "ignorePaths": ["**/node_modules/**", "**/.venv/**", "**/venv/**", "**/__pycache__/**"]
}
